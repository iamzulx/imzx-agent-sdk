{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "adapters/**/*.ts",
    "application/**/*.ts",
    "domain/**/*.ts",
    "interfaces/**/*.ts"
  ]
}
