{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@adapters/*": ["./adapters/*"],
      "@interfaces/*": ["./interfaces/*"],
      "@domain/*": ["./domain/*"],
      "@application/*": ["./application/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*", "interfaces/**/*", "adapters/**/*", "domain/**/*", "application/**/*", "bin/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
