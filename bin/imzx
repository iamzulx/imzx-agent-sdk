#!/usr/bin/env bash
# imzx CLI entry point
# Usage: imzx run "prompt" / imzx chat / imzx serve

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Find tsx — prefer local, fallback to global
if [ -x "$PROJECT_ROOT/node_modules/.bin/tsx" ]; then
  TSX="$PROJECT_ROOT/node_modules/.bin/tsx"
elif command -v tsx &>/dev/null; then
  TSX="tsx"
elif command -v npx &>/dev/null; then
  TSX="npx tsx"
else
  echo "Error: tsx not found. Install with: npm install -g tsx" >&2
  exit 1
fi

exec $TSX "$PROJECT_ROOT/interfaces/cli/cli-handler.ts" "$@"
