# imzx-agent-sdk Configuration
# Copy to .env and fill in your values.

# LLM API Configuration (choose one provider)

# OpenRouter (recommended — supports many models)
OPENROUTER_API_KEY=your_key_here
# IMZX_LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Anthropic (direct)
# ANTHROPIC_API_KEY=your_key_here

# OpenAI
# OPENAI_API_KEY=your_key_here

# Custom provider (any OpenAI-compatible endpoint)
# IMZX_API_KEY=your_key_here
# IMZX_LLM_BASE_URL=https://your-server.com/v1/chat/completions

# Model selection (default: anthropic/claude-sonnet-4)
# IMZX_MODEL=anthropic/claude-sonnet-4

# Tool approval (set to 'true' to skip interactive approval prompts)
# IMZX_AUTO_APPROVE=false

# REST API authentication (optional — protects /api/* endpoints)
# IMZX_API_KEY=your_api_key_here
