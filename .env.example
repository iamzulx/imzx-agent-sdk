# imzx-agent-sdk Configuration
# Supports ANY OpenAI-compatible endpoint
# Set ONE provider's API key and it auto-detects the rest

# === LLM API Configuration ===
# Option 1: OpenRouter (recommended — many models)
OPENROUTER_API_KEY=your_k...n

# Option 2: OpenAI direct
# OPENAI_API_KEY=sk-...n

# Option 3: Anthropic direct
# ANTHROPIC_API_KEY=sk-ant-...n

# Option 4: Together AI
# TOGETHER_API_KEY=...n
# IMZX_LLM_BASE_URL=https://api.together.xyz/v1/chat/completions
# IMZX_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# option 5: Groq
# GROQ_API_KEY=gsk_...n
# IMZX_LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions
# IMZX_MODEL=llama-3.3-70b-versatile

# option 6: Any OpenAI-compatible endpoint
# IMZX_API_KEY=*** IMZX_LLM_BASE_URL=https://your-server.com/v1/chat/completions
# IMZX_MODEL=your-model-name

# === Agent Configuration ===
# IMZX_AUTO_APPROVE=false   # Skip tool approval prompts
# IMZX_API_KEY=your_a...n  # REST API authentication key
